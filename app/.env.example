# ─────────────────────────────────────────────
# ODI Platform — Production Environment
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# Required: set a strong password for the database
DB_PASSWORD=change-me-to-a-strong-password

# Required: generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret

# Required: your VPS IP or domain (no trailing slash)
APP_URL=http://YOUR_VPS_IP
